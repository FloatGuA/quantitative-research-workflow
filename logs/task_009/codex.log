+                        "Annual Return": "{:.2%}",
+                        "Annual Volatility": "{:.2%}",
+                        "Sharpe Ratio": "{:.3f}",
+                        "Max Drawdown": "{:.2%}",
+                        "Win Rate": "{:.2%}",
+                        "Total Fee Cost": "{:.4f}",
+                    }
