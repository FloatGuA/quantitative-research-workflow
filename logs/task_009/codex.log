+
+                cum_value = (1 + portfolio["strategy_return"]).cumprod()
+                portfolio["cum_return"] = cum_value - 1
+                portfolio["drawdown"] = (cum_value - cum_value.cummax()) / cum_value.cummax()
+                return portfolio
