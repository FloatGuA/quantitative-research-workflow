+
+            def lag_signal_analysis(frame):
+                records = []
+                for lag in [0, 1, 2, 3]:
+                    score = frame["sentiment_score"] if lag == 0 else frame[f"sentiment_lag{lag}"]
+                    signals = (score > 0.1).astype(int) - (score < -0.1).astype(int)
